@AgentTeams.SampleApi_HostAddress = http://localhost:5062
@EmployeeWriterToken = replace-with-development-token

GET {{AgentTeams.SampleApi_HostAddress}}/api/v1/products/
Accept: application/json

###

GET {{AgentTeams.SampleApi_HostAddress}}/api/v1/products/1
Accept: application/json

###

GET {{AgentTeams.SampleApi_HostAddress}}/api/v1/employees
Accept: application/json

###

POST {{AgentTeams.SampleApi_HostAddress}}/api/v1/auth/dev-token
Content-Type: application/json

{
  "subject": "local",
  "name": "Local User",
  "scopes": ["employees.write"]
}

###

POST {{AgentTeams.SampleApi_HostAddress}}/api/v1/employees
Content-Type: application/json
Authorization: Bearer {{EmployeeWriterToken}}

{
  "employeeCode": "EMP-001",
  "fullName": "Nguyen Van A",
  "email": "nguyen.van.a@example.com",
  "department": "Engineering",
  "jobTitle": "Backend Engineer"
}

###

GET {{AgentTeams.SampleApi_HostAddress}}/api/v1/employees/storage
Accept: application/json

###

GET {{AgentTeams.SampleApi_HostAddress}}/openapi/v1.json
Accept: application/json

###
