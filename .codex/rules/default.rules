# Project-local Codex command rules.
#
# Codex loads this file only when the project `.codex/` layer is trusted.
# Rules apply to commands that request execution outside the sandbox.
# Test changes with:
#   codex execpolicy check --pretty --rules .codex/rules/default.rules -- <command>

prefix_rule(
    pattern = ["git", "reset", "--hard"],
    decision = "forbidden",
    justification = "Do not discard user or teammate work. Use git status and targeted patches instead.",
    match = [
        "git reset --hard",
        "git reset --hard HEAD",
    ],
    not_match = [
        "git reset --soft HEAD~1",
    ],
)

prefix_rule(
    pattern = ["git", "clean"],
    decision = "prompt",
    justification = "Cleaning untracked files can remove user work. Confirm the exact target first.",
    match = [
        "git clean -fd",
        "git clean -fdx",
    ],
    not_match = [
        "git status --short",
    ],
)

prefix_rule(
    pattern = ["git", "push"],
    decision = "prompt",
    justification = "Pushing publishes local state. Confirm branch and intent before running.",
    match = [
        "git push",
        "git push origin main",
    ],
    not_match = [
        "git status --short",
    ],
)

prefix_rule(
    pattern = ["Remove-Item", "-Recurse"],
    decision = "prompt",
    justification = "Recursive deletion needs an explicit path review before execution.",
    match = [
        "Remove-Item -Recurse .\\tmp",
        "Remove-Item -Recurse -Force .\\tmp",
    ],
    not_match = [
        "Get-ChildItem -Recurse",
    ],
)

prefix_rule(
    pattern = ["rg"],
    decision = "allow",
    justification = "Repo search is safe and routinely needed for context gathering.",
    match = [
        "rg employee src",
        "rg --files",
    ],
)

prefix_rule(
    pattern = ["git", "status"],
    decision = "allow",
    justification = "Git status is safe and required before scoped edits.",
    match = [
        "git status --short",
        "git status",
    ],
)

prefix_rule(
    pattern = ["git", "diff"],
    decision = "allow",
    justification = "Git diff is read-only and required for review.",
    match = [
        "git diff",
        "git diff --check",
    ],
)

prefix_rule(
    pattern = ["dotnet", "build"],
    decision = "allow",
    justification = "Project build is the expected verification step for this template.",
    match = [
        "dotnet build",
        "dotnet build src\\AgentTeams.SampleApi\\AgentTeams.SampleApi.csproj",
    ],
)

prefix_rule(
    pattern = ["dotnet", "test"],
    decision = "allow",
    justification = "Project tests are the expected verification step for this template.",
    match = [
        "dotnet test",
        "dotnet test src\\AgentTeams.SampleApi.Tests\\AgentTeams.SampleApi.Tests.csproj",
    ],
)

prefix_rule(
    pattern = ["powershell", "-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "./scripts/Invoke-AgentHarness.ps1"],
    decision = "allow",
    justification = "The unified agent harness is the expected project verification entrypoint.",
    match = [
        "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/Invoke-AgentHarness.ps1 -Mode Quick",
        "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/Invoke-AgentHarness.ps1 -Mode Full",
        "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/Invoke-AgentHarness.ps1 -Mode Status",
    ],
)
